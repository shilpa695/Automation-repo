<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cross Browser Testing">

	<test thread-count="5" name="Chrome Test">
		<parameter name="browser" value="Chrome"></parameter>
		<classes>

			<class name="testScripts.LoginTest">
				<methods>
					<include name="verifyUserLoginWithValidCredentials"></include>
					<include
						name="verifyUserLoginWithvalidUsernameAndInValidPassword"></include>
				</methods>
			</class>

		</classes>
	</test> <!--
	Test -->
	<test thread-count="5" name="Firefox Test">
		<parameter name="browser" value="Firefox"></parameter>
		<classes>

			<class name="testScripts.LoginTest">
				<methods>
					<include name="verifyUserLoginWithValidCredentials"></include>
					<include
						name="verifyUserLoginWithvalidUsernameAndInValidPassword"></include>
				</methods>
			</class>

		</classes>
	</test> <!--
	Test -->
</suite> <!--
Suite -->
